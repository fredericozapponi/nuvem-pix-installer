# Nuvem PIX — modelo de ambiente de PRODUÇÃO.
# O deploy/install.sh gera o .env real a partir daqui (preenche __PLACEHOLDERS__ e gera segredos).
# NUNCA comite o .env real.

APP_ENV=production
HTTP_ADDR=:8080

# ---- Domínio / HTTPS (Caddy) ----
DOMAIN=__DOMAIN__
ACME_EMAIL=__ACME_EMAIL__

# ---- Banco / cache ----
POSTGRES_USER=nuvempix
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=nuvempix
DATABASE_URL=postgres://nuvempix:__POSTGRES_PASSWORD__@postgres:5432/nuvempix?sslmode=disable
REDIS_URL=redis://redis:6379/0

# ---- MQTT (backend <-> EMQX, rede interna) ----
MQTT_BROKER_URL=tcp://emqx:1883
MQTT_CLIENT_ID=nuvem-pix-backend
MQTT_USERNAME=backend
MQTT_PASSWORD=__MQTT_PASSWORD__
MQTT_TLS_INSECURE=false
EMQX_AUTH_TOKEN=__EMQX_AUTH_TOKEN__
EMQX_NODE_COOKIE=__EMQX_NODE_COOKIE__

# ---- Admin global (criado no 1º boot) ----
ADMIN_EMAIL=__ADMIN_EMAIL__
ADMIN_PASSWORD=__ADMIN_PASSWORD__

# ---- Endereço que as PLACAS usam (HTTP/1883 nesta v1) ----
DEVICE_BACKEND_URL=http://__DOMAIN__:8080
DEVICE_MQTT_HOST=__DOMAIN__
DEVICE_MQTT_PORT=1883

# ---- Arquivos persistentes (volume ./data) ----
FIRMWARE_DIR=/app/data/firmware
LANDING_DIR=/app/data/landing

# ---- Pix / Mercado Pago ----
# As credenciais (token/segredo) são POR ESTABELECIMENTO, configuradas no painel
# (Estabelecimentos → Recebimento / dono em Recebimento). Deixe vazias aqui.
PIX_PROVIDER=__PIX_PROVIDER__
MP_ACCESS_TOKEN=
MP_BASE_URL=https://api.mercadopago.com
PIX_WEBHOOK_BASE_URL=https://__DOMAIN__
MP_WEBHOOK_SECRET=
PIX_PAYER_EMAIL=__PIX_PAYER_EMAIL__

# ---- JWT / tempos ----
JWT_SECRET=__JWT_SECRET__
JWT_TTL=24h
HEARTBEAT_TTL=60s
MONITOR_TICK=20s
PIX_PENDING_TTL=30m
